# ---------------------------------------------------------------------------
# SitePitch environment variables (example)
# Copy to .env.local and fill in your values.
# ---------------------------------------------------------------------------

# Convex deployment
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
SITE_URL=https://trysitepitch.com

# Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Analytics (self-hosted Rybbit, cookie-free, no user identification)
# Leave RYBBIT_SITE_ID empty to disable the tracking script entirely.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_RYBBIT_HOST=https://rybbit.matthias.lol
NEXT_PUBLIC_RYBBIT_SITE_ID=

# ---------------------------------------------------------------------------
# Platform support access
# Comma-separated list of email addresses that may access /app/admin/operations.
# Server-side only; never expose to the browser.
# Example: SUPPORT_ADMIN_EMAILS=admin@example.com,support@example.com
# ---------------------------------------------------------------------------
SUPPORT_ADMIN_EMAILS=

# ---------------------------------------------------------------------------
# Provider cost reconciliation thresholds (optional, server-side only)
# ---------------------------------------------------------------------------
PROVIDER_COST_ALERT_USD=0.50
PROVIDER_COST_ALERT_PERCENT=0.05

# Lemon Squeezy billing (server-side)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_TEST_MODE=true
LEMONSQUEEZY_STARTER_VARIANT_ID=
LEMONSQUEEZY_PRO_VARIANT_ID=
LEMONSQUEEZY_AGENCY_VARIANT_ID=
LEMONSQUEEZY_CREDIT_PACK_VARIANT_ID=
