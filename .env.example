# ---------------------------------------------------------------------------
# SitePitch environment variables (example)
# Copy to .env.local and fill in your values.
# ---------------------------------------------------------------------------

# Convex deployment
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
SITE_URL=https://trysitepitch.com

# White-label report domains (server-side)
# Customers point their report subdomain to this CNAME target. DNS verification
# does not provision ingress or TLS; support activates a domain after hosting is ready.
REPORT_DOMAIN_CNAME_TARGET=reports.trysitepitch.com

# Public report password protection (Cloudflare Turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Analytics (self-hosted Rybbit, cookie-free, no user identification)
# Leave RYBBIT_SITE_ID empty to disable the tracking script entirely.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_RYBBIT_HOST=https://rybbit.matthias.lol
NEXT_PUBLIC_RYBBIT_SITE_ID=

# ---------------------------------------------------------------------------
# Platform support access
# Comma-separated list of email addresses that may access /app/admin/operations.
# Server-side only; never expose to the browser.
# Example: SUPPORT_ADMIN_EMAILS=admin@example.com,support@example.com
# ---------------------------------------------------------------------------
SUPPORT_ADMIN_EMAILS=

# ---------------------------------------------------------------------------
# Provider cost reconciliation thresholds (optional, server-side only)
# ---------------------------------------------------------------------------
PROVIDER_COST_ALERT_USD=0.50
PROVIDER_COST_ALERT_PERCENT=0.05

# Lemon Squeezy billing (server-side)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_TEST_MODE=true
LEMONSQUEEZY_STARTER_VARIANT_ID=
LEMONSQUEEZY_PRO_VARIANT_ID=
LEMONSQUEEZY_AGENCY_VARIANT_ID=
LEMONSQUEEZY_CREDIT_PACK_VARIANT_ID=

# ---------------------------------------------------------------------------
# Workspace integrations (server-side, opt-in)
# Keep disabled until OAuth apps, callback URLs, and the encrypted keyring are set.
# Keyring format: {"current":"v1","keys":{"v1":"<base64-32-byte-key>"}}
# ---------------------------------------------------------------------------
INTEGRATIONS_ENABLED=false
PUBLIC_API_ENABLED=false
PUBLIC_API_BASE_URL=
INTEGRATIONS_DISABLED_PROVIDERS=
INTEGRATION_CREDENTIAL_KEYRING=
INTEGRATION_OAUTH_REDIRECT_URL=https://your-convex-site.convex.site/api/integrations/oauth/callback
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=
# Use separate Google OAuth clients/projects so revoking Gmail does not revoke Sheets.
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=
GOOGLE_SHEETS_CLIENT_ID=
GOOGLE_SHEETS_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Eve runtime and strict release evals (server-side)
# Use the same service credentials on the Convex caller and the Next/Eve runtime.
# Eval ingestion accepts only the signed, sanitized reporter payload.
# ---------------------------------------------------------------------------
EVE_RUNTIME_ENABLED=false
EVE_RUNTIME_URL=http://127.0.0.1:3000
EVE_RUNTIME_SERVICE_USERNAME=sitepitch-convex
EVE_RUNTIME_SERVICE_PASSWORD=
EVE_EVALS_ENABLED=false
EVE_EVAL_INGEST_URL=
EVE_EVAL_REPORTER_SECRET=
AI_GATEWAY_API_KEY=
